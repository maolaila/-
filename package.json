{
  "name": "light-commerce-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:round1": "pnpm lint && pnpm typecheck && pnpm test",
    "test:round2": "pnpm build",
    "test:round3": "pnpm test:e2e",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "deploy:check": "tsx scripts/deploy-check.ts",
    "deploy:init": "tsx scripts/deploy-check.ts --seed --db --storage && pnpm db:migrate && pnpm db:seed",
    "deploy:verify": "pnpm deploy:check && pnpm audit --audit-level moderate --registry https://registry.npmjs.org && pnpm test:round1 && pnpm test:round2"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@supabase/supabase-js": "^2.49.4",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.6",
    "postgres": "^3.4.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.54.2",
    "sanitize-html": "^2.14.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.12",
      "postcss": ">=8.5.15"
    }
  }
}
